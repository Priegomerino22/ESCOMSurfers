PORT=3000
CORS_ORIGIN=*

# Para correr localmente:
# 1. Descarga una llave de cuenta de servicio desde Firebase Console.
# 2. Renómbrala como serviceAccountKey.json.
# 3. Colócala dentro de la carpeta server/.
# 4. Descomenta esta línea si hace falta:
# GOOGLE_APPLICATION_CREDENTIALS=./serviceAccountKey.json
